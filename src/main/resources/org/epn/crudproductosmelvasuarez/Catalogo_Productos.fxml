<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<Pane prefHeight="637.0" prefWidth="580.0" style="-fx-background-color: #749CEA;" xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.epn.crudproductosmelvasuarez.controlador.CatalogosProdController">

    <children>

        <Label layoutX="125.0" layoutY="40.0" text="CATÁLOGO DE PRODUCTOS">
            <font>
                <Font name="System Bold" size="24.0" />
            </font>
        </Label>

        <Label layoutX="100.0" layoutY="120.0" text="ID:" />
        <Label layoutX="100.0" layoutY="160.0" text="Código:" />
        <Label layoutX="100.0" layoutY="200.0" text="Producto:" />
        <Label layoutX="100.0" layoutY="240.0" text="Precio:" />

        <TextField fx:id="txtId" editable="false" layoutX="220.0" layoutY="115.0" prefWidth="170.0" />
        <TextField fx:id="txtCodigo" layoutX="220.0" layoutY="155.0" prefHeight="25.0" prefWidth="222.0" />
        <TextField fx:id="txtNombre" layoutX="220.0" layoutY="195.0" prefHeight="25.0" prefWidth="222.0" />
        <TextField fx:id="txtPrecio" layoutX="220.0" layoutY="235.0" prefHeight="25.0" prefWidth="222.0" />

        <Button fx:id="btnBuscar" layoutX="392.0" layoutY="115.0" onAction="#buscar" text="Buscar" />
        <Button fx:id="btnInsertar" layoutX="90.0" layoutY="290.0" onAction="#insertar" text="Insertar" />
        <Button fx:id="btnModificar" layoutX="180.0" layoutY="290.0" onAction="#modificar" text="Modificar" />
        <Button fx:id="btnMostrar" layoutX="285.0" layoutY="290.0" onAction="#mostrarTodos" text="Mostrar" />
        <Button fx:id="btnEliminar" layoutX="385.0" layoutY="290.0" onAction="#eliminar" text="Eliminar" textFill="RED" />

        <TableView fx:id="tablaProductos" layoutX="70.0" layoutY="340.0" prefHeight="180.0" prefWidth="440.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="60.0" text="ID" />
                <TableColumn fx:id="colCodigo" prefWidth="100.0" text="Código" />
                <TableColumn fx:id="colProducto" prefWidth="180.0" text="Producto" />
                <TableColumn fx:id="colPrecio" prefWidth="100.0" text="Precio" />
            </columns>
        </TableView>

        <Button fx:id="btnImprimirReporte" layoutX="90.0" layoutY="550.0" onAction="#imprimirReporte" text="Imprimir Reporte" />
        <Button fx:id="btnCerrarSesion" layoutX="350.0" layoutY="550.0" onAction="#cerrarSesion" style="-fx-font-weight: bold;" text="Regresar" textFill="#fa0909" />

    </children>
</Pane>
